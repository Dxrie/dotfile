{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#110e2290",
                "editor.background": "#110e2290",
                "editor.foreground": "#c3c2c7",
                "text": "#c3c2c7",
                "text.muted": "#c3c2c770",
                "text.ignored": "#c3c2c740",
                "text.placeholder": "#c3c2c750",
                "ignored": "#c3c2c730",
                "element.hover": "#c3c2c730",
                "ghost_element.hover": "#6D71B430",
                "ghost_element.selected": "#6D71B430",
                "ghost_element.active": "#6D71B460",
                "border": "#110e22",
                "editor.highlighted_line.background": "#6D71B410",
                "editor.active_line.background": "#6D71B410",
                "panel.background": "#110e2290",
                "title_bar.background": "#110e2290",
                "title_bar.inactive_background": "#110e2290",
                "status_bar.background": "#110e2290",
                "drop_target.background": "#110e2290",
                "elevated_surface.background": "#110e22",
                "toolbar.background": "#110e2290",
                "tab_bar.background": "#110e2290",
                "tab.inactive_background": "#110e2290",
                "tab.active_background": "#6D71B430",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#110e22",
                "scrollbar.thumb.background": "#6D71B4",
                "editor.gutter.background": "#110e2290",
                "terminal.background": "#110e2210",
                "terminal.foreground": "#c3c2c7",
                "terminal.dim_foreground": "#c3c2c7",
                "terminal.bright_foreground": "#c3c2c7",
                "terminal.ansi.black": "#110e22",
                "terminal.ansi.red": "#6D71B4",
                "terminal.ansi.green": "#737AC2",
                "terminal.ansi.yellow": "#82709B",
                "terminal.ansi.blue": "#8F749E",
                "terminal.ansi.magenta": "#A07CC3",
                "terminal.ansi.cyan": "#9F8DAE",
                "terminal.ansi.white": "#c3c2c7",
                "terminal.ansi.bright_black": "#615e72",
                "terminal.ansi.bright_red": "#6D71B4",
                "terminal.ansi.bright_green": "#737AC2",
                "terminal.ansi.bright_yellow": "#82709B",
                "terminal.ansi.bright_blue": "#8F749E",
                "terminal.ansi.bright_magenta": "#A07CC3",
                "terminal.ansi.bright_cyan": "#9F8DAE",
                "terminal.ansi.bright_white": "#c3c2c7",
                "modified": "#6D71B4",
                "syntax": {
                    "attribute": {
                        "color": "#6D71B4"
                    },
                    "boolean": {
                      "color": "#737AC2"
                    },
                    "comment": {
                      "color": "#615e72"
                    },
                    "comment.doc": {
                      "color": "#615e72"
                    },
                    "constant": {
                      "color": "#737AC2"
                    },
                    "function": {
                      "color": "#9F8DAE"
                    },
                    "keyword": {
                      "color": "#8F749E"
                    },
                    "number": {
                      "color": "#A07CC3"
                    },
                    "operator": {
                      "color": "#8F749E"
                    },
                    "string": {
                      "color": "#6D71B4"
                    },
                    "variable": {
                      "color": "#737AC2"
                    }
                },
                "players": [
                  {
                    "cursor": "#6D71B4",
                    "background": "#110e22",
                    "selection": "#6D71B430"
                  }
                ]
            }
        }
    ]
}
